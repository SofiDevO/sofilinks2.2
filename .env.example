SITE_URL=
# ── Youtube
CHANNEL_ID="your_channel_id"
YT_API_KEY="your_youtube_API_KEY"
YT_SECRET="secret_para_validar_firma_hmac_del_webhook"  # Debe coincidir con hub.secret al suscribirse al PubSubHubbub
UPLOADS_PLAYLIST_ID="UU36_js-krsAHAEAWpEDhHtw"

# ── GitHub Actions (para el webhook y el deploy)
# PAT con permisos: contents:write (fine-grained) o repo (classic)
# Crear en GitHub → Settings → Developer settings → Personal access tokens
GH_PAT=
GH_REPO=SofiDevO/sofilinks2.2

# ── GitHub Secrets (NO van aquí — configurar directamente en el repo de GitHub)
# VERCEL_DEPLOY_HOOK_URL → GitHub → repo → Settings → Secrets and variables → Actions
# YT_SECRET             → GitHub → repo → Settings → Secrets and variables → Actions


# ── Wordpress Headless
WPGRAPHQL_URL="https://your-wordpress-api.com/api"
BEARER_TOKEN="You need to generate a barear token" #check README.md

# ── Stories API ──────────────────────────────────────
# PUBLIC_STORIES_API_URL=https://stories-api.sofidev.top
PUBLIC_STORIES_API_URL= # sin valor → se usa el default del schema: http://localhost:8787
PUBLIC_STORIES_API_KEY=YOUR_API_KEY
STORIES_COOKIE_SECRET=SUPER_ULTRA_SECRET
