---
---

<div class="stories-footer">
  <form class="stories-reply-form" id="stories-reply-form">
    <input
      type="text"
      id="stories-reply-input"
      class="stories-reply-input"
      placeholder="Responder a la story..."
      autocomplete="off"
    />
    <button type="submit" id="stories-reply-send" class="stories-reply-send" disabled>Send</button>
  </form>

  <!-- Minimalist comment bubble icon button with count badge (visible only when comments exist) -->
  <button id="stories-comments-btn" class="stories-comments-btn hidden" aria-label="Ver comentarios">
    <svg
      class="comment-icon"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
    </svg>
    <span id="stories-comments-count" class="stories-comments-count">0</span>
  </button>

  <button id="stories-like-btn" class="stories-like-btn" aria-label="Dar like">
    <svg
      class="heart-icon"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    <span id="stories-like-count" class="stories-like-count">0</span>
  </button>
</div>

<style>
  .stories-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 30;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px 12px 24px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 100%);
    pointer-events: all;
  }

  .stories-reply-form {
    flex: 1;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    padding: 4px 6px 4px 12px;
    backdrop-filter: blur(8px);
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;

    &:focus-within {
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.35);
    }
  }

  .stories-reply-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: white;
    font-size: 0.82rem;
    height: 32px;
    padding: 0;

    &::placeholder {
      color: rgba(255, 255, 255, 0.6);
    }
  }

  .stories-reply-send {
    background: none;
    border: none;
    color: #a855f7;
    font-weight: 600;
    font-size: 0.82rem;
    cursor: pointer;
    padding: 0 8px;
    height: 32px;
    display: flex;
    align-items: center;
    opacity: 0;
    transform: translateX(5px);
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;

    &:not(:disabled) {
      opacity: 1;
      transform: translateX(0);
      pointer-events: all;
    }

    &:hover {
      color: #c084fc;
    }
  }

  .stories-comments-btn,
  .stories-like-btn {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    height: 40px;
    padding: 0 12px;
    backdrop-filter: blur(8px);
    transition:
      transform 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      background-color 0.2s ease,
      border-color 0.2s ease;

    &.hidden {
      display: none !important;
    }

    &:hover {
      background: rgba(255, 255, 255, 0.18);
      border-color: rgba(255, 255, 255, 0.35);
    }

    &:active {
      transform: scale(0.92);
    }
  }

  .stories-comments-btn {
    color: rgba(255, 255, 255, 0.9);
  }

  .stories-comments-count,
  .stories-like-count {
    font-size: 0.8rem;
    font-weight: 500;
  }

  .stories-like-btn.is-liked {
    background: rgba(236, 72, 153, 0.15);
    border-color: rgba(236, 72, 153, 0.45);
    color: #ec4899;

    .heart-icon {
      fill: #ec4899;
      animation: heart-pop 0.3s ease-out forwards;
    }
  }

  @keyframes heart-pop {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.3);
    }
    100% {
      transform: scale(1);
    }
  }
</style>
