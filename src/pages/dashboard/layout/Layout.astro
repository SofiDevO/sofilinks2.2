---
import BaseHead from "@core/components/BaseHead.astro";
import ThemeButton from "@src/shared/components/ThemeButton.astro";

const { title, description } = Astro.props;
import { ClientRouter } from "astro:transitions";

const pathname = Astro.url.pathname;

const navItems = [
  { label: "Overview", href: "/dashboard", icon: "mdi:view-dashboard-outline" },
  {
    label: "Stories",
    href: "/dashboard/stories",
    icon: "mdi:movie-open-outline",
  },
  {
    label: "Comentarios",
    href: "/dashboard/comments",
    icon: "mdi:comment-text-multiple-outline",
  },
  { label: "Baneos", href: "/dashboard/bans", icon: "mdi:shield-lock-outline" },
];
---

<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter slot="header" />
  </head>
  <body class="flex flex-col min-h-screen w-full">
    <ThemeButton class="fixed bottom-5 right-5 z-[100]" iconColor="#140030" />
    <div class="dashboard-grid">
      <div class="dashboad-sidebar">
        <header class="header flex items-start w-full justify-between relative">
          <a
            href="/"
            class="logo flex items-center justify-center overflow-hidden w-10 h-auto"
          >
            <img
              src="/img/favicon.png"
              alt="Panel de control"
              class="w-full h-full object-contain"
            />
          </a>
          <button
            id="toggle-sidebar"
            class="dashboard-button cursor-pointer flex items-center justify-center rounded-sm absolute -right-8 top-0 bg-violet-800/30 w-fit px-1"
          >
            <iconify-icon
              icon="fluent:panel-left-24-filled"
              width="30"
              height="30"
              style="color:var(--color-color-text); background-color:transparent; "
            ></iconify-icon>
          </button>
        </header>
        <nav class="sidebar-nav">
          <ul>
            {
              navItems.map((item) => {
                const isActive =
                  pathname === item.href ||
                  (item.href !== "/dashboard" &&
                    pathname.startsWith(item.href));
                return (
                  <li>
                    <a
                      href={item.href}
                      class:list={["nav-link", { active: isActive }]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      <iconify-icon icon={item.icon} width="22" height="22" />
                      <span class="nav-label">{item.label}</span>
                    </a>
                  </li>
                );
              })
            }
          </ul>
          <div class="nav-divider"></div>
          <a
            href="/api/auth/logout"
            class="nav-link logout-link"
            id="logout-btn"
          >
            <iconify-icon icon="mdi:logout" width="22" height="22"
            ></iconify-icon>
            <span class="nav-label">Cerrar sesion</span>
          </a>
        </nav>
      </div>
      <main class="dashboard-main">
        <slot name="main" />
      </main>
    </div>
  </body>
</html>

<style is:inline>
  .dashboard-grid {
    --sidebar-width: 6rem;
    --sidebar-padding: 2rem 1rem;
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    grid-template-rows: auto 1fr;
    grid-template-areas:
      "sidebar main "
      "sidebar main ";
    width: 100%;
    min-height: 100vh;
    transition: grid-template-columns 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    &:has(> .dashboad-sidebar.active) {
      --sidebar-width: 220px;
      --sidebar-padding: 2rem;
    }
    @media (max-width: 768px) {
      --sidebar-width: 4rem;
      --sidebar-padding: 1rem;
      &.sidebar-open {
        --sidebar-width: 260px;
      }
    }
  }

  .dashboad-sidebar {
    grid-area: sidebar;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem;
    border-right: 1px solid
      color-mix(in srgb, var(--color-color-text) 12%, transparent);
    background: color-mix(
      in srgb,
      var(--color-primary) 95%,
      var(--color-caracol) 5%
    );
    /* overflow: hidden; */
  }

  .dashboard-main {
    grid-area: main;
    display: flex;
    padding: 2rem;
    flex-direction: column;
    align-items: stretch;
    overflow-y: auto;
    max-height: 100vh;
  }

  .logo {
    margin-bottom: 1.5rem;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 1;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .sidebar-nav ul {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.65rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-color-text);
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease-in-out;
    white-space: nowrap;
    overflow: hidden;
  }

  .nav-link:hover {
    background-color: color-mix(in srgb, var(--color-caracol) 15%, transparent);
    color: var(--color-caracol);
  }

  .nav-link.active {
    background-color: color-mix(in srgb, var(--color-caracol) 20%, transparent);
    color: var(--color-caracol);
    font-weight: 600;
  }

  .nav-link iconify-icon {
    flex-shrink: 0;
  }

  .nav-label {
    opacity: 0;
    width: 0;
    overflow: hidden;
    transition:
      opacity 0.2s ease,
      width 0.2s ease;
  }

  .dashboad-sidebar.active .nav-label {
    opacity: 1;
    width: auto;
  }

  .nav-divider {
    height: 1px;
    width: 100%;
    background: color-mix(in srgb, var(--color-color-text) 12%, transparent);
    margin: auto 0 0.5rem 0;
  }

  .logout-link {
    color: #e74c3c;
  }

  .logout-link:hover {
    background-color: color-mix(in srgb, #e74c3c 12%, transparent);
    color: #c0392b;
  }
</style>

<script>
  const toggleSidebar = document.querySelector(
    "#toggle-sidebar",
  ) as HTMLElement;
  const sidebar = document.querySelector(".dashboad-sidebar") as HTMLElement;

  let userPreferences = { active: false };
  const storedPreferences = localStorage.getItem("dashboard-preferences");

  if (storedPreferences) {
    userPreferences = JSON.parse(storedPreferences);
    if (userPreferences.active) {
      sidebar.classList.add("active");
      toggleSidebar.classList.add("active");
    }
  }

  toggleSidebar.addEventListener("click", (e) => {
    e.preventDefault();
    userPreferences.active = !userPreferences.active;

    sidebar.classList.toggle("active", userPreferences.active);
    toggleSidebar.classList.toggle("active", userPreferences.active);

    localStorage.setItem(
      "dashboard-preferences",
      JSON.stringify(userPreferences),
    );
  });
</script>
