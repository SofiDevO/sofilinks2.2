---
import { isAuthenticated } from "@src/shared/utils/auth";
import Layout from "./layout/Layout.astro";
import { serverFetch } from "@features/dashboard/services/server-fetch";
import type { Story } from "@features/stories/types/stories.types";
import StoriesPanel from "@features/dashboard/components/StoriesPanel.tsx";

const payload = await isAuthenticated(Astro.cookies);

if (!payload) {
  return Astro.redirect("/login");
}

const storiesRes = await serverFetch<Story[]>(Astro.cookies, "/api/v1/stories");
const stories = storiesRes.data ?? [];
---

<Layout title="Stories - Dashboard" description="Gestion de stories">
  <section slot="main" class="stories-page">
    <div class="stories-header">
      <div>
        <h1 class="page-title">Stories</h1>
        <p class="page-subtitle">Gestiona tus historias efimeras</p>
      </div>
    </div>

    <StoriesPanel initialStories={stories} client:load />
  </section>
</Layout>

<style is:inline>
  .stories-page {
    width: 100%;
    max-width: 1100px;
  }

  .stories-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-color-text);
    margin: 0 0 0.25rem 0;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-color-text) 60%, transparent);
    margin: 0;
  }
</style>
