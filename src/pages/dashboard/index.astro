---
import Layout from "./layout/Layout.astro";
import { serverFetch } from "@features/dashboard/services/server-fetch";
import type { Story } from "@features/stories/types/stories.types";

import { isAuthenticated } from "@src/shared/utils/auth";
const payload = await isAuthenticated(Astro.cookies);

if (!payload) {
  return Astro.redirect("/login");
}

// Fetch all data server-side for the overview
const storiesRes = await serverFetch<Story[]>(Astro.cookies, "/api/v1/stories");

interface DashboardStats {
  storiesCount: number;
  commentsCount: number;
  likesCount: number;
  bansCount: number;
}

const statsRes = await serverFetch<DashboardStats>(
  Astro.cookies,
  "/api/v1/admin/stats",
);

const stories = storiesRes.data ?? [];
const dashboardStats = statsRes.data ?? {
  storiesCount: 0,
  commentsCount: 0,
  likesCount: 0,
  bansCount: 0,
};

const stats = [
  {
    label: "Stories activas",
    value: dashboardStats.storiesCount,
    icon: "mdi:movie-open-outline",
    color: "#8b5cf6",
    gradient:
      "linear-gradient(135deg, rgba(139,92,246,0.15), rgba(139,92,246,0.05))",
  },
  {
    label: "Comentarios",
    value: dashboardStats.commentsCount,
    icon: "mdi:comment-text-multiple-outline",
    color: "#3b82f6",
    gradient:
      "linear-gradient(135deg, rgba(59,130,246,0.15), rgba(59,130,246,0.05))",
  },
  {
    label: "Likes totales",
    value: dashboardStats.likesCount,
    icon: "mdi:heart-outline",
    color: "#ef4444",
    gradient:
      "linear-gradient(135deg, rgba(239,68,68,0.15), rgba(239,68,68,0.05))",
  },
  {
    label: "IPs baneadas",
    value: dashboardStats.bansCount,
    icon: "mdi:shield-lock-outline",
    color: "#f59e0b",
    gradient:
      "linear-gradient(135deg, rgba(245,158,11,0.15), rgba(245,158,11,0.05))",
  },
];
---

<Layout title="Dashboard" description="Panel de administracion">
  <section slot="main" class="dashboard-overview">
    <h1 class="overview-title">Panel de control</h1>
    <p class="overview-subtitle">
      Resumen de actividad en las ultimas 24 horas
    </p>

    <div class="stats-grid">
      {
        stats.map((stat) => (
          <article
            class="stat-card"
            style={`--stat-color: ${stat.color}; --stat-gradient: ${stat.gradient};`}
          >
            <div class="stat-icon-wrapper">
              <iconify-icon
                icon={stat.icon}
                width="28"
                height="28"
                style={`color: ${stat.color};`}
              />
            </div>
            <div class="stat-content">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          </article>
        ))
      }
    </div>

    {
      stories.length > 0 && (
        <section class="recent-section">
          <h2 class="section-title">Stories recientes</h2>
          <div class="recent-stories">
            {stories.slice(0, 4).map((story) => (
              <a href="/dashboard/stories" class="recent-story-card">
                <div class="story-video-thumb">
                  <video
                    src={`${story.videoUrl}#t=0.5`}
                    muted
                    playsinline
                    preload="metadata"
                    class="thumb-video"
                  />
                  <div class="thumb-overlay">
                    <iconify-icon
                      icon="mdi:play-circle-outline"
                      width="32"
                      height="32"
                    />
                  </div>
                </div>
                <span class="story-date">
                  {new Date(story.createdAt).toLocaleDateString("es-MX", {
                    day: "numeric",
                    month: "short",
                    hour: "2-digit",
                    minute: "2-digit",
                  })}
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </section>
</Layout>

<style is:inline>
  .dashboard-overview {
    width: 100%;
    max-width: 1100px;
  }

  .overview-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-color-text);
    margin: 0 0 0.25rem 0;
  }

  .overview-subtitle {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-color-text) 60%, transparent);
    margin: 0 0 2rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .stat-card {
    background: var(--stat-gradient);
    border: 1px solid color-mix(in srgb, var(--stat-color) 20%, transparent);
    border-radius: 1rem;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px
      color-mix(in srgb, var(--stat-color) 15%, transparent);
  }

  .stat-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--stat-color) 12%, transparent);
    flex-shrink: 0;
  }

  .stat-content {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-color-text);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--color-color-text) 60%, transparent);
    font-weight: 500;
  }

  .recent-section {
    margin-top: 1rem;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-color-text);
    margin: 0 0 1rem 0;
  }

  .recent-stories {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
  }

  .recent-story-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--color-card);
    border: 1px solid
      color-mix(in srgb, var(--color-color-text) 8%, transparent);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .recent-story-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .story-video-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    background: #1a1a2e;
  }

  .thumb-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    color: white;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .recent-story-card:hover .thumb-overlay {
    opacity: 1;
  }

  .story-date {
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-color-text) 60%, transparent);
    padding: 0.25rem 0.75rem 0.75rem;
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .recent-stories {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
