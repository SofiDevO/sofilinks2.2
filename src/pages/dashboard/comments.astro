---
import { isAuthenticated } from "@src/shared/utils/auth";
import Layout from "./layout/Layout.astro";
import { serverFetch } from "@features/dashboard/services/server-fetch";
import type { Story, Comment } from "@features/stories/types/stories.types";
import CommentsPanel from "@features/dashboard/components/CommentsPanel.tsx";

const payload = await isAuthenticated(Astro.cookies);

if (!payload) {
  return Astro.redirect("/login");
}

const storiesRes = await serverFetch<Story[]>(Astro.cookies, "/api/v1/stories");
const stories = storiesRes.data ?? [];

// Fetch admin comments (with IP) for each story
interface StoryWithComments {
  story: Story;
  comments: Comment[];
}

const storiesWithComments: StoryWithComments[] = [];

for (const story of stories) {
  const commentsRes = await serverFetch<Comment[]>(
    Astro.cookies,
    `/api/v1/admin/stories/${story.id}/comments`,
  );
  storiesWithComments.push({
    story,
    comments: commentsRes.data ?? [],
  });
}
---

<Layout title="Comentarios - Dashboard" description="Moderacion de comentarios de las stories">
  <section slot="main" class="comments-page">
    <div class="comments-header">
      <div>
        <h1 class="page-title">Comentarios</h1>
        <p class="page-subtitle">Modera comentarios y bloquea abusos de IP directamente</p>
      </div>
    </div>

    <CommentsPanel initialStoriesWithComments={storiesWithComments} client:load />
  </section>
</Layout>

<style is:inline>
  .comments-page {
    width: 100%;
    max-width: 1100px;
  }

  .comments-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-color-text);
    margin: 0 0 0.25rem 0;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-color-text) 60%, transparent);
    margin: 0;
  }
</style>
