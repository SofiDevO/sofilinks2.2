---
interface Props {
  id?: string;
  name?: string;
  autocomplete?: string;
  label?: string;
}

const {
  id = "password",
  name = "password",
  autocomplete = "current-password",
  label = "Password",
} = Astro.props;

const toggleId = `toggle-${id}`;
const eyeId = `eye-${id}`;
const eyeOffId = `eye-off-${id}`;
---

<label class="block tsxt-sm font-medium text-gray-400 mb-1" for={id}
  >{label}</label
>
<div
  class="password-wrapper w-full px-4 py-2 outline-none rounded-xl bg-violet-600/30 text-white focus:outline-none"
>
  <input
    type="password"
    {name}
    {id}
    {autocomplete}
    required
    class="password-input"
  />
  <button
    type="button"
    id={toggleId}
    class="password-toggle"
    aria-label="Mostrar contraseña"
    data-input-id={id}
    data-eye-id={eyeId}
    data-eye-off-id={eyeOffId}
  >
    <iconify-icon icon="mdi:eye" id={eyeId} width="20" height="20"
    ></iconify-icon>
    <iconify-icon
      icon="mdi:eye-off"
      id={eyeOffId}
      width="20"
      height="20"
      style="display:none"></iconify-icon>
  </button>
</div>

<script>
  document
    .querySelectorAll<HTMLButtonElement>(".password-toggle")
    .forEach((btn) => {
      const inputId = btn.dataset.inputId!;
      const eyeId = btn.dataset.eyeId!;
      const eyeOffId = btn.dataset.eyeOffId!;

      const input = document.getElementById(inputId) as HTMLInputElement;
      const iconEye = document.getElementById(eyeId)!;
      const iconEyeOff = document.getElementById(eyeOffId)!;

      // Toggle visibility on click
      btn.addEventListener("click", () => {
        const isHidden = input.type === "password";
        input.type = isHidden ? "text" : "password";
        iconEye.style.display = isHidden ? "none" : "";
        iconEyeOff.style.display = isHidden ? "" : "none";
        btn.setAttribute(
          "aria-label",
          isHidden ? "Ocultar contraseña" : "Mostrar contraseña",
        );
      });

      // Before submit: always reset to type="password" so the value is
      // sent correctly and password managers don't get confused
      const form = btn.closest("form");
      form?.addEventListener("submit", () => {
        input.type = "password";
        iconEye.style.display = "";
        iconEyeOff.style.display = "none";
        btn.setAttribute("aria-label", "Mostrar contraseña");
      });
    });
</script>

<style>
  .password-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .password-input {
    color: white;
    width: 100%;
    padding-right: 2.5rem !important;
    border-radius: 10px;
    padding: 0.25rem;
    &:active {
      outline: none;
    }
    &:focus {
      outline: none;
    }
  }

  .password-toggle {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #888;
    display: flex;
    align-items: center;
  }

  .password-toggle:hover {
    color: var(--color-softpurple, #ca95ff);
  }
</style>
