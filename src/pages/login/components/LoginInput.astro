---
interface Props {
  name: "username" | "password";
  type: "text" | "password";
  id: string;
  label: string;
}

const { name, type, id, label } = Astro.props;
---

<div>
  <label for={id} class="block tsxt-sm font-medium text-gray-400 mb-1">
    {label}
  </label>
  <input
    type={type}
    name={name}
    id={id}
    required
    class="w-full px-4 py-2 outline-none rounded-xl bg-violet-600/30 text-white focus:outline-none"
  />
</div>
